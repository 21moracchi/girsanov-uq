#!/bin/bash
# Loop over all matching replica directories
for dir in FV_replica_*/ ; do
    if [ -d "$dir" ]; then
        echo "Entering directory: $dir"
        
        # Enter the directory, submit the job, then return to the parent
        (cd "$dir" && sbatch job)
        
        # Optional delay to avoid overloading the Slurm scheduler
        sleep 0.5
    fi
done

echo "All submissions are complete."

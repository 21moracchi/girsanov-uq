#!/bin/bash


# Ensure the log directory exists
mkdir -p logs

# Loop over all matching replica directories
for dir in ams_* ; do
    if [ -d "$dir" ]; then
        echo "Entering directory: $dir"

        # Enter the directory, submit the job, then return to the parent
        # Note: replace 'job_ini' with the name of your compute script
        (cd "$dir" && ccc_msub job_topaze)

        # Scheduler delay
        sleep 0.5
    fi
done

echo "All submissions are complete."
